<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="JADY.Views.UnsavedChangesWindow"
        Title="UnsavedChangesWindow">
        
        <StackPanel Orientation="Vertical">
                <TextBlock>You have unsaved changes</TextBlock>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Name="SaveButton" Click="SaveButton_OnClick">SAVE</Button>
                        <Button Click="QuitButton_OnClick">QUIT</Button>
                        <Button Click="CloseButton_OnClick">CLOSE</Button>
                </StackPanel>
        </StackPanel>
        
</Window>
