<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <StyleInclude Source="BorderStyles.axaml"/>
    <StyleInclude Source="ButtonStyles.axaml"/>
    <StyleInclude Source="LabelStyles.axaml"/>
    <StyleInclude Source="PathIconStyles.axaml"/>
    <StyleInclude Source="ScrollBarStyles.axaml"/>
    <StyleInclude Source="TextBlockStyles.axaml"/>
    
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBox VerticalAlignment="Center">blah blah blah</TextBox>
                <ComboBox VerticalAlignment="Center">blah blah blah</ComboBox>
                <DatePicker VerticalAlignment="Center"></DatePicker>
            </StackPanel>
        </Border>
    </Design.PreviewWith>
    
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Consolas"/>
    </Style>
    
    <Style Selector="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        <Setter Property="Background" Value="{DynamicResource InsetControlBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="10,10"/>
    </Style>
    
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Margin" Value="2"/>
    
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}"/>
        <Setter Property="Background" Value="{DynamicResource InsetControlBackground}"/>
    </Style>

    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Background" Value="{DynamicResource InsetControlBackground}"/>
        <Setter Property="Effect">
            <DropShadowEffect BlurRadius="2" Color="{DynamicResource SystemAccentColor}" OffsetX="0" OffsetY="0" Opacity="1"/>
        </Setter>
    </Style>
    
    <Style Selector="ComboBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        <Setter Property="Background" Value="{DynamicResource InsetControlBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="10, 9"/>
    </Style>
    
    <Style Selector="ComboBox /template/ Border#Background">
    
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}"/>
        <Setter Property="Background" Value="{DynamicResource InsetControlBackground}"/>
    </Style>

    <Style Selector="ComboBox:focused /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>
    
    <Style Selector="DatePicker">
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="{DynamicResource InsetControlBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    
    <Style Selector="DatePicker /template/ TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="DatePicker /template/ Button#PART_Button">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="DatePicker:pointerover /template/ Button#PART_Button">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}"/>
    </Style>

    <Style Selector="DatePicker:focused /template/ Button#PART_Button">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
    </Style>
    
    <Style Selector="CheckBox">
        <Setter Property="Padding" Value="8,0,0,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="CheckBox:unchecked /template/ Border#NormalRectangle">
        <Setter Property="CornerRadius" Value="4"/> 
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource InsetControlBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
    
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}"/>
    </Style>

    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="CornerRadius" Value="4"/> 
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    
</Styles>