<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:JADY.ViewModels"
        xmlns:converters="clr-namespace:JADY.UI.Converters"
        mc:Ignorable="d" d:DesignWidth="335" d:DesignHeight="360"
        x:Class="JADY.UI.Views.Dialogs.EditEntryWindow"
        x:DataType="vm:DiaryEntryViewModel"
        Title="Edit entry"
        Width="335"
        Height="400"
        MinWidth="335"
        MinHeight="290">
    
    <Window.Resources>
        <converters:DateTimeToOffsetConverter x:Key="DateConverter"></converters:DateTimeToOffsetConverter>
    </Window.Resources>
        
    <Grid RowDefinitions="Auto, Auto, *, Auto, Auto" Margin="10">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, *" Margin="5">
            <TextBox Grid.Column="0" Name="EntryCategory" Text="{Binding Category, Mode=OneTime}" PlaceholderText="Category..." Margin="5"></TextBox>
            <TextBox Grid.Column="1" Name="EntrySubcategory" Text="{Binding SubCategory, Mode=OneTime}" PlaceholderText="Subcategory..." Margin="5"></TextBox>
        </Grid>
        
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto" Margin="5">
            <TextBox Grid.Column="0" Name="EntryTitle" Text="{Binding Title, Mode=OneTime}" PlaceholderText="Title..." Margin="5"></TextBox>
            <ComboBox Grid.Column="2" Name="EntryStatus" VerticalAlignment="Center" PropertyChanged="EntryStatus_OnPropertyChanged" SelectedIndex="{Binding Status, Mode=OneTime}" Margin="5"></ComboBox>
        </Grid>
        
        <TextBox Grid.Row="2" Name="EntryContent" Text="{Binding Content, Mode=OneTime}" TextWrapping="Wrap" PlaceholderText="Content..." Margin="10"></TextBox>
        
        <Panel Grid.Row="3" Margin="5">
            <CalendarDatePicker Name="EntryDate" 
                                SelectedDate="{Binding Date, Mode=OneTime, Converter={StaticResource DateConverter}}" 
                                SelectedDateFormat="Custom"
                                HorizontalAlignment="Left"
                                Margin="5"
                                ToolTip.Tip="Actual start date of an event or a date of a one time entry. (The date of adding an entry is saved automatically.)"/>
            
            <CalendarDatePicker Name="EntryEndDate" 
                                SelectedDate="{Binding EndDate, Mode=OneTime, Converter={StaticResource DateConverter}}" 
                                SelectedDateFormat="Custom" 
                                HorizontalAlignment="Right"
                                Margin="5"
                                ToolTip.Tip="End date of an event"/>
        </Panel>
        
        <Panel Grid.Row="4" Margin="5">
            
            <IconToggleButton Name="EntryIsHidden" 
                              IsChecked="{Binding IsHidden, Mode=OneTime}" 
                              IconData="{StaticResource EyeIconSolid}" 
                              CheckedIconData="{StaticResource EyeSlashIconSolid}" 
                              HorizontalAlignment="Left" 
                              Margin="5"/>
            
            <HoverButton Click="Submit_OnClick" Margin="5" HorizontalAlignment="Right">EDIT</HoverButton>
        </Panel>
    </Grid>
        
</Window>