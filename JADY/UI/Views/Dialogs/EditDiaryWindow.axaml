<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:JADY.ViewModels"
        mc:Ignorable="d" d:DesignWidth="180" d:DesignHeight="100"
        x:Class="JADY.UI.Views.Dialogs.EditDiaryWindow"
        x:DataType="viewModels:DiaryViewModel"
        Title="Edit diary"
        SizeToContent="Height"
        Width="180"
        MinWidth="100"
        MinHeight="100">
        
        <Grid ColumnDefinitions="*, Auto"  HorizontalAlignment="Center" VerticalAlignment="Center" ColumnSpacing="10" Margin="10">
                <TextBox Grid.Column="0" Name="DiaryName" PropertyChanged="DiaryNameOnPropertyChanged" Text="{Binding Name, Mode=OneTime}"></TextBox>
                <IconButton Grid.Column="1" Classes="accent" Name="SubmitButton" IconData="{StaticResource PencilIconSolid}" Click="Submit_OnClick" HorizontalAlignment="Center"/>
        </Grid>
        
</Window>
