<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:JADY.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="JADY.UI.Views.Dialogs.LinkEntryWindow"
        x:DataType="viewModels:DiaryEntryViewModel"
        Title="LinkEntryWindow">
    
    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="10">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, *" Margin="5">
            <TextBox Grid.Column="0" Name="EntryCategory" PlaceholderText="Category..." Margin="5" Text="{Binding Category}" IsReadOnly="True"/>
            <TextBox Grid.Column="1" Name="EntrySubcategory" PlaceholderText="Subcategory..." Margin="5" Text="{Binding SubCategory}" IsReadOnly="True"/>
        </Grid>
        
        <TextBox Grid.Row="1" Name="EntryTitle" PlaceholderText="Title..." Margin="10"/>
        
        <TextBox Grid.Row="2" Name="EntryContent" TextWrapping="Wrap" PlaceholderText="Content..." Margin="10"/>
        
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="5" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="5">
                <DatePicker Name="EntryDate">
                    <ToolTip.Tip>Actual start date of an event or a date of a one time entry. (The date of adding an entry is saved automatically.)</ToolTip.Tip>
                </DatePicker>
            </StackPanel>
            
            <Panel Margin="5">
                <CheckBox Name="EntryIsHidden" HorizontalAlignment="Left">Hidden</CheckBox>
                <HoverButton Click="Submit_OnClick" Margin="5" HorizontalAlignment="Center">ADD</HoverButton>
            </Panel>
        </StackPanel>
    </Grid>
        
</Window>