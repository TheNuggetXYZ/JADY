<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:JADY.UI.Views.Controls">
    <Design.PreviewWith>
        <Border Padding="20">
            <controls:HoverButton Content="Button"/>
        </Border>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type controls:HoverButton}" TargetType="controls:HoverButton" 
                  BasedOn="{StaticResource {x:Type Button}}">
        
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_LayoutRoot"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    
                    <ContentPresenter x:Name="PART_MyContentPresenter" Content="{TemplateBinding Content}"></ContentPresenter>
                    
                </Border>
            </ControlTemplate>
        </Setter>
        
        <Style Selector="^ /template/ Border#PART_LayoutRoot">
            <Setter Property="BoxShadow" Value="1 2 2 -1 black"/>
            <Setter Property="Margin" Value="2"/> 
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.1"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="BoxShadow" Value="2 3 2 -1 black"/>
            <Setter Property="RenderTransform" Value="translate(-1px, -1px)"/>
        </Style>
        
        <Style Selector="^:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="BoxShadow" Value="1 2 2 -1 black"/>
            <Setter Property="RenderTransform" Value="scale(0.95) translate(1px, 1px)"/>
        </Style>
        
    </ControlTheme>
</ResourceDictionary>
