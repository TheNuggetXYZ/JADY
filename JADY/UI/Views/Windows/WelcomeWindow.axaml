<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:JADY.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="JADY.UI.Views.Windows.WelcomeWindow"
        x:DataType="viewModels:WelcomeWindowViewModel"
        Title="Welcome!"
        Icon="/Assets/Icons/JADY_32x.png"
        SizeToContent="WidthAndHeight">
    
    <StackPanel Orientation="Vertical" Spacing="10" Margin="20">
        <HoverButton Click="ContinueButton_OnClick">Continue</HoverButton>
    </StackPanel>
    
</Window>
