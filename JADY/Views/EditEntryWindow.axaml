<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:JADY.ViewModels"
        mc:Ignorable="d" d:DesignWidth="335" d:DesignHeight="360"
        x:Class="JADY.Views.EditEntryWindow"
        x:DataType="vm:DiaryEntryViewModel"
        Title="Edit entry"
        Width="335"
        Height="400"
        MinWidth="335"
        MinHeight="290">
        
    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="10">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, *" Margin="5">
            <TextBox Grid.Column="0" Name="EntryCategory" Text="{Binding Category, Mode=OneTime}" PlaceholderText="Category..." Margin="5"></TextBox>
            <TextBox Grid.Column="1" Name="EntrySubcategory" Text="{Binding SubCategory, Mode=OneTime}" PlaceholderText="Subcategory..." Margin="5"></TextBox>
        </Grid>
        
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto" Margin="5">
            <TextBox Grid.Column="0" Name="EntryTitle" Text="{Binding Title, Mode=OneTime}" PlaceholderText="Title..." Margin="5"></TextBox>
            <ComboBox Grid.Column="2" Name="EntryStatus" SelectedIndex="{Binding Status, Mode=OneTime}" Margin="5"></ComboBox>
        </Grid>
        
        <TextBox Grid.Row="2" Name="EntryContent" Text="{Binding Content, Mode=OneTime}" TextWrapping="Wrap" PlaceholderText="Content..." Margin="10"></TextBox>
        
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="5" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="5">
                <DatePicker Name="EntryDate" SelectedDate="{Binding Date, Mode=OneTime}">
                    <ToolTip.Tip>Actual start date of an event or a date of a one time entry. (The date of adding an entry is saved automatically.)</ToolTip.Tip>
                </DatePicker>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="5">
                <DatePicker Name="EntryEndDate" SelectedDate="{Binding EndDate, Mode=OneTime}">
                    <ToolTip.Tip>End date of an event</ToolTip.Tip>
                </DatePicker>
            </StackPanel>
            
            <Panel Margin="5">
                <CheckBox Name="EntryIsHidden" IsChecked="{Binding IsHidden, Mode=OneTime}" HorizontalAlignment="Left">Hidden</CheckBox>
                <Button Click="Submit_OnClick" Margin="5" HorizontalAlignment="Center">EDIT</Button>
            </Panel>
        </StackPanel>
    </Grid>
        
</Window>