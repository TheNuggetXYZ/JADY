<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Orientation="Vertical" Spacing="10">
                <IconButton IconData="{StaticResource SettingsIconSolid}" IconText="Settings" IconSize="8"/>
                <IconButton IconData="{StaticResource BurgerMenuIconSolid}"/>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type IconButton}" TargetType="IconButton" 
                  BasedOn="{StaticResource {x:Type HoverButton}}">
        
        <Style Selector="^ /template/ ContentPresenter#PART_MyContentPresenter">
            <Setter Property="ContentTemplate">
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <PathIcon Data="{Binding $parent[IconButton].IconData}" 
                                  Width="{Binding $parent[IconButton].IconSize}"
                                  Height="{Binding $parent[IconButton].IconSize}"/>
                            
                        <TextBlock Text="{Binding $parent[IconButton].IconText}"/>
                    </StackPanel>
                </DataTemplate>
            </Setter>
        </Style>
        
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="4"/>
        
        <Style Selector="^ /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
        </Style>
        
        <Style Selector="^:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
        </Style>
    </ControlTheme>
</ResourceDictionary>
