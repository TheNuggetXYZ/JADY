<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:JADY.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="JADY.Views.DiaryEntry"
             x:DataType="viewModels:DiaryEntryViewModel">
    
    
    <Border Background="DimGray">
        <Grid ColumnDefinitions="*, Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Margin="5" Text="{Binding Category}"></TextBlock>
                <TextBlock Margin="5" Text="{Binding Title}"></TextBlock>
                <TextBlock Margin="5" Text="{Binding Content}"></TextBlock>
            </StackPanel>
                                
            <TextBlock Grid.Column="1" Margin="5" Text="{Binding LogDate}"></TextBlock>
        </Grid>
    </Border>
    
</UserControl>
