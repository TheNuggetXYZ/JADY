<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Orientation="Vertical">
                <Button Classes="round">Round</Button>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <Style Selector="Button.invisible /template/ ContentPresenter">
        <Setter Property="BoxShadow" Value="0 0 0 0 transparent"/>
        <Setter Property="Margin" Value="0 0 0 0"/>
        <Setter Property="Padding" Value="0 0 0 0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    
    <Style Selector="Button.diaryEntryButton:pressed">
        <Setter Property="RenderTransform" Value="scale(0.995)"/>
    </Style>
    
    <Style Selector="Button.round">
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="24,12"/> 
        <Setter Property="CornerRadius" Value="24"/> 
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        
        <Setter Property="FontWeight" Value="400"/>
        <Setter Property="FontSize" Value="16"/>
    
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.12"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.round:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
    </Style>

    <Style Selector="Button.round:pressed">
        <Setter Property="RenderTransform" Value="scale(0.96)"/>
    </Style>

    <Style Selector="Button.round:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
    </Style>
</Styles>
