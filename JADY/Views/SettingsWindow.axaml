<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="JADY.Views.SettingsWindow"
        Title="SettingsWindow"
        SizeToContent="WidthAndHeight">
        
    <Grid RowDefinitions="Auto, Auto, Auto" Margin="10" RowSpacing="10">
        <CheckBox Grid.Row="0" Name="ShowHidden">Show hidden entries</CheckBox>
        
        <TextBox Grid.Row="1" Name="SavePath">
            <TextBox.InnerRightContent>
                <Button Click="ChangeSavePath_OnClick">+</Button>
            </TextBox.InnerRightContent>
        </TextBox>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
            <Button Click="Close_OnClick">CLOSE</Button>
            <Button Click="SaveClose_OnClick" Content="SAVE &amp; CLOSE"></Button>
            <Button Click="Save_OnClick">SAVE</Button>
        </StackPanel>
    </Grid>
        
</Window>