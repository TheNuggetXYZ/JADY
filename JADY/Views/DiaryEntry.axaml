<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:JADY.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="JADY.Views.DiaryEntry"
             x:DataType="viewModels:DiaryEntryViewModel">
    
    <Border Background="{DynamicResource SystemChromeMediumColor}" CornerRadius="5" PointerPressed="DiaryEntryHeader_OnPointerPressed">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Edit"/>
                <MenuItem Header="Delete"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Grid Margin="5" RowDefinitions="Auto, *, Auto">
            <Panel Grid.Row="0">
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <TextBlock Text="{Binding Category}"></TextBlock>
                    <TextBlock Text="{Binding SubCategoryStringWithPipeSeparator}"></TextBlock>
                </StackPanel>
                <TextBlock HorizontalAlignment="Center" Text="{Binding Title}"></TextBlock>
                <TextBlock HorizontalAlignment="Right" Text="{Binding LogDate}"></TextBlock>
            </Panel>
            
            <Panel Grid.Row="1" Name="ObjectToOpen0" Margin="10">
                <Border Background="{DynamicResource SystemRegionColor}" CornerRadius="5">
                    <TextBlock Margin="5" TextWrapping="Wrap" Text="{Binding Content}"></TextBlock>
                </Border>
            </Panel>
            
            <Panel Grid.Row="2" Name="ObjectToOpen1">
                <TextBlock HorizontalAlignment="Left" Text="{Binding Date}"></TextBlock>
                <TextBlock HorizontalAlignment="Right" Text="{Binding EndDate}"></TextBlock>
            </Panel>
        </Grid>
    </Border>
    
</UserControl>
