<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:JADY.ViewModels"
        mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="150"
        x:Class="JADY.Views.AddDiaryWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Title="Add a diary"
        SizeToContent="Height"
        Width="180">
        
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" Margin="10">
                <TextBox Text="{Binding NewDiaryName}"></TextBox>
                <Button Command="{Binding AddDiaryCommand}" HorizontalAlignment="Center">ADD</Button>
        </StackPanel>
        
</Window>
