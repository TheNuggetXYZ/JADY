<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:JADY.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="JADY.Views.DiaryEntryControl"
             x:DataType="viewModels:DiaryEntryViewModel">
    
    <Border Background="{DynamicResource SystemChromeMediumColor}" CornerRadius="5" PointerPressed="DiaryEntryHeader_OnPointerPressed" IsVisible="{Binding !IsHidden}">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Edit" Command="{Binding EditCommand}"/>
                <MenuItem Header="End" Command="{Binding OpenEndWindowCommand}" IsVisible="{Binding ShowEndEventInContextMenu}"/>
                <MenuItem Header="Delete" Command="{Binding RemoveCommand}"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Grid Margin="5" RowDefinitions="Auto, *, Auto">
            <Panel Grid.Row="0">
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <TextBlock Text="{Binding Category}"/>
                    <TextBlock Text="{Binding SubCategoryStringWithPipeSeparator}"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Center" Text="{Binding Title}"/>
                <TextBlock HorizontalAlignment="Right" Text="{Binding LogDate}"/>
            </Panel>
            
            <Panel Grid.Row="1" Name="ObjectToOpen0" Margin="10">
                <Border Background="{DynamicResource SystemRegionColor}" CornerRadius="5">
                    <TextBlock Margin="5" TextWrapping="Wrap" Text="{Binding Content}"/>
                </Border>
            </Panel>
            
            <Panel Grid.Row="2" Name="ObjectToOpen1">
                <TextBlock HorizontalAlignment="Left" Text="{Binding Date}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock>
                        <Run Text="{Binding GetStatusDisplayNameWithSpace}"/>
                        <Run Text="{Binding GetTypeDisplayName}"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" Text="{Binding EndDate}"/>
            </Panel>
        </Grid>
    </Border>
    
</UserControl>
