<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="JADY.UI.Views.Dialogs.YesNoDialogWindow"
        Title="?"
        SizeToContent="WidthAndHeight">
    
    <StackPanel Orientation="Vertical" Spacing="30" 
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Margin="50 30">
        
        <SelectableTextBlock Name="MessageText" Classes="h4" HorizontalAlignment="Center"/>
                
        <StackPanel Orientation="Horizontal" Spacing="10" 
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                    
            <Button Name="YesButton" Classes="round accent" Click="YesButton_OnClick">Yes</Button>
            <Button Name="NoButton" Classes="round" Click="NoButton_OnClick">No</Button>
        </StackPanel>
    </StackPanel>
    
</Window>
