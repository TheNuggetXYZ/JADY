<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Orientation="Vertical" Spacing="10">
                <TextBlock Classes="h1">This is h1!</TextBlock>
                <TextBlock Classes="h2">This is h2!</TextBlock>
                <TextBlock Classes="h3">This is h3!</TextBlock>
                <TextBlock Classes="h4">This is h4!</TextBlock>
                <TextBlock>This is a TextBlock!</TextBlock>
                <TextBlock Classes="paragraph">This is a paragraph, paragraph, paragraph, paragraph, <LineBreak/> paragraph, paragraph, paragraph, paragraph!</TextBlock>
                <TextBlock Classes="greyedOut">This is greyed out</TextBlock>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <Style Selector="TextBlock.h1">
        <Setter Property="FontWeight" Value="900"/>
        <Setter Property="FontSize" Value="22"/>
    </Style>
    
    <Style Selector="TextBlock.h2">
        <Setter Property="FontWeight" Value="700"/>
        <Setter Property="FontSize" Value="20"/>
    </Style>
    
    <Style Selector="TextBlock.h3">
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>
    
    <Style Selector="TextBlock.h4">
        <Setter Property="FontWeight" Value="400"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>
    
    <Style Selector="TextBlock">
        <Setter Property="FontWeight" Value="300"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
    
    <Style Selector="TextBlock.paragraph">
        <Setter Property="FontWeight" Value="300"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Opacity" Value="0.8"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    
    <Style Selector="TextBlock.greyedOut">
        <Setter Property="Foreground" Value="Gray"/>
    </Style>
</Styles>
