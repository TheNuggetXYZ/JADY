<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <ThemeVariantScope RequestedThemeVariant="Light">
            <Border Padding="20" Background="White">
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <IconButton IconData="{StaticResource SettingsIconSolid}" IconText="Settings" IconSize="8"/>
                    <IconButton Classes="accent" IconData="{StaticResource SettingsIconSolid}" IconText="Settings" IconSize="8"/>
                    <IconButton IconData="{StaticResource BurgerMenuIconSolid}"/>
                    <IconButton Classes="accent" IconData="{StaticResource BurgerMenuIconSolid}"/>
                    <IconButton Classes="highlightOnlyBg" IconData="{StaticResource BurgerMenuIconSolid}"/>
                    <IconButton Classes="accent highlightOnlyBg" IconData="{StaticResource BurgerMenuIconSolid}"/>
                    <IconButton>dwadawd</IconButton>
                </StackPanel>
            </Border>
        </ThemeVariantScope>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type IconButton}" TargetType="IconButton" 
                  BasedOn="{StaticResource {x:Type Button}}">
        
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="CornerRadius" Value="32"></Setter>
    
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_HitboxBorder" Background="Transparent">
                    <Border x:Name="PART_LayoutRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                
                        <ContentPresenter x:Name="PART_MyContentPresenter" 
                                          Content="{TemplateBinding Content}"/>
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>
    
        <Style Selector="^ /template/ ContentPresenter#PART_MyContentPresenter">
            <Setter Property="ContentTemplate">
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <PathIcon Data="{Binding $parent[IconButton].IconData}" 
                                  Width="{Binding $parent[IconButton].IconSize}"
                                  Height="{Binding $parent[IconButton].IconSize}"
                                  Foreground="{Binding $parent[IconButton].Foreground}"
                                  IsVisible="{Binding $parent[IconButton].Content, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                        
                        <ContentPresenter Content="{Binding $parent[IconButton].Content}" IsVisible="{Binding $parent[IconButton].Content, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"></ContentPresenter>
                        
                        <TextBlock Text="{Binding $parent[IconButton].IconText}" IsVisible="{Binding $parent[IconButton].IconText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </DataTemplate>
            </Setter>
        </Style>
    
        <Style Selector="^ /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="2"/> 
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
    
        <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
        </Style>
    
        <Style Selector="^:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}"/>
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
            <Setter Property="RenderTransform" Value="scale(0.95)"/>
        </Style>
        
        <!-- accent -->
        <Style Selector="^.accent /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"></Setter>
        </Style>
        
        <Style Selector="^.accent">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="^.accent:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}"></Setter>
        </Style>
        
        <Style Selector="^.accent:pointerover">
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>

        <Style Selector="^.accent:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark2}"></Setter>
        </Style>
        
        <Style Selector="^.accent:pressed">
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
        
        <!-- white -->
        <Style Selector="^.white">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="^.white:pointerover">
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
        
        <Style Selector="^.white:pressed">
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
        
        <!-- highlightOnlyBg -->
        <Style Selector="^.highlightOnlyBg /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent"></Setter>
        </Style>

        <Style Selector="^.highlightOnlyBg:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource ButtonTransparencyBgPointerover}"></Setter>
        </Style>

        <Style Selector="^.highlightOnlyBg:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource ButtonTransparencyBgPressed}"></Setter>
        </Style>
        
        <Style Selector="^.highlightOnlyBg.accent">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"></Setter>
            
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="^.highlightOnlyBg.accent:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"></Setter>
        </Style>
        
        <Style Selector="^.highlightOnlyBg.accent:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>

        <Style Selector="^.highlightOnlyBg.accent:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}"></Setter>
        </Style>

        <Style Selector="^.highlightOnlyBg.accent:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
        
    </ControlTheme>
</ResourceDictionary>
